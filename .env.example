# Copy to .env and fill in. Pre-solve all auth BEFORE the hackathon.
# .env is gitignored — never commit real keys.

# Backend (producers + agent + actuators point here).
# Local dev: http://127.0.0.1:8000 / ws://127.0.0.1:8000/ws
# Live demo (point laptop producers at Railway):
#   https://golden-coffee-production.up.railway.app  /  wss://.../ws
BACKEND_URL=http://127.0.0.1:8000
BACKEND_WS=ws://127.0.0.1:8000/ws

# Agent (Claude). Leave blank to run the deterministic rule-based policy.
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-opus-4-8

# Spotify (needs Premium + an active device; redirect must be 127.0.0.1, not localhost)
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# ---- Comfort devices (the visitor-comfort autopilot) ----

# AC / heater via a Broadlink RM4 IR blaster.
#   python -m actuators.infrared --discover        -> fill BROADLINK_HOST
#   python -m actuators.infrared --learn cool|warm -> fill the IR codes below (hex)
BROADLINK_HOST=
BROADLINK_IR_COOL=
BROADLINK_IR_WARM=

# Smart lighting via a Philips Hue bridge (press the bridge button, then run
#   python -m actuators.lights 70 warm   to pair on first use).
HUE_BRIDGE_IP=
HUE_GROUP=

# Xiaomi / Mijia devices over local miIO (lamp + scent diffuser).
# Region of your Mi-Home account — "cn" for mainland China (default), else e.g.
# de / us / sg / ru / i2. Tokens must be pulled from the matching server.
XIAOMI_REGION=cn
# Mi account creds, used ONLY by the local cloud token helper (read-only):
#   python -m actuators.xiaomi --cloud   -> prints each device's ip + token
XIAOMI_MI_USER=
XIAOMI_MI_PASS=
#   python -m actuators.xiaomi lamp 70 warm         -> test the lamp
#   python -m actuators.xiaomi diffuser 60          -> test the diffuser
# When set, these take priority over Hue (lamp) and the webhook/IR (diffuser).
XIAOMI_LAMP_IP=
XIAOMI_LAMP_TOKEN=
XIAOMI_DIFFUSER_IP=
XIAOMI_DIFFUSER_TOKEN=
# MIoT diffusers only: the on/off + level property ids from the device's MIoT spec
# (home.miot-spec.com). Leave blank for legacy set_power diffusers.
XIAOMI_DIFFUSER_SIID=
XIAOMI_DIFFUSER_PIID_ON=
XIAOMI_DIFFUSER_PIID_LEVEL=
XIAOMI_DIFFUSER_LEVEL_MAX=3

# Scent diffuser (non-Xiaomi) — EITHER a webhook (Home Assistant / Shelly / IFTTT) ...
SCENT_WEBHOOK_URL=
# ... OR reuse the Broadlink IR blaster with learned diffuser codes (hex).
SCENT_IR_ON=
SCENT_IR_OFF=

# Telegram staff notifications.
#   @BotFather -> /newbot -> TELEGRAM_TOKEN
#   message the bot, then: python -m actuators.notify --chat-id  -> TELEGRAM_CHAT_ID
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Optional shared secret: if set, producers must send it as X-Token on /ingest + /frame
INGEST_TOKEN=

# LLM backup (Gemini AI Studio key, format AIza... ) — used when ANTHROPIC_API_KEY absent
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
