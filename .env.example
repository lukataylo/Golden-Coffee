# Copy to .env and fill in. Pre-solve all auth BEFORE the hackathon.
# .env is gitignored — never commit real keys.

# Backend (producers + agent + actuators point here).
# Local dev: http://127.0.0.1:8000 / ws://127.0.0.1:8000/ws
# Live demo (point laptop producers at Railway):
#   https://golden-coffee-production.up.railway.app  /  wss://.../ws
BACKEND_URL=http://127.0.0.1:8000
BACKEND_WS=ws://127.0.0.1:8000/ws

# Agent (Claude). Leave blank to run the deterministic rule-based policy.
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-opus-4-8

# Spotify (needs Premium + an active device; redirect must be 127.0.0.1, not localhost)
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# ---- Comfort devices (the visitor-comfort autopilot) ----

# AC / heater via a Broadlink RM4 IR blaster.
#   python -m actuators.infrared --discover        -> fill BROADLINK_HOST
#   python -m actuators.infrared --learn cool|warm -> fill the IR codes below (hex)
BROADLINK_HOST=
BROADLINK_IR_COOL=
BROADLINK_IR_WARM=

# Smart lighting via a Philips Hue bridge (press the bridge button, then run
#   python -m actuators.lights 70 warm   to pair on first use).
HUE_BRIDGE_IP=
HUE_GROUP=

# ---- Xiaomi / Mijia (lamp + scent diffuser) ----
# Region of your Mi-Home account — "cn" for mainland China (default), else e.g.
# de / us / sg / ru / i2. Tokens AND cloud control use this server.
XIAOMI_REGION=cn
# Mi account creds. Used by the token helper AND (in cloud mode) to send commands.
#   python -m actuators.xiaomi --cloud   -> prints each device's ip / token / did
XIAOMI_MI_USER=
XIAOMI_MI_PASS=
# Transport: auto (local if set up, else cloud) | local (same-LAN miIO) | cloud
# (via the Mi cloud — use this when the devices live in China and this machine
# is elsewhere). When set, Xiaomi takes priority over Hue / webhook / IR.
XIAOMI_TRANSPORT=cloud

# -- LOCAL transport (same-LAN miIO): ip + 32-char token per device --
#   python -m actuators.xiaomi lamp 70 warm     /     diffuser 60   (to test)
XIAOMI_LAMP_IP=
XIAOMI_LAMP_TOKEN=
XIAOMI_DIFFUSER_IP=
XIAOMI_DIFFUSER_TOKEN=

# -- CLOUD transport: address devices by `did` (from --cloud above) --
XIAOMI_LAMP_DID=
XIAOMI_DIFFUSER_DID=

# MIoT property ids from the device's spec at home.miot-spec.com. Defaults match
# common Mijia light/diffuser services; override if a write does nothing.
# Lamp (light service): on / brightness / colour-temp piids.
XIAOMI_LAMP_SIID=2
XIAOMI_LAMP_PIID_ON=1
XIAOMI_LAMP_PIID_BRIGHT=2
XIAOMI_LAMP_PIID_CT=
# Diffuser: on/off + optional level. Leave SIID/PIID blank for legacy set_power
# diffusers on LOCAL transport (cloud needs them).
XIAOMI_DIFFUSER_SIID=2
XIAOMI_DIFFUSER_PIID_ON=1
XIAOMI_DIFFUSER_PIID_LEVEL=
XIAOMI_DIFFUSER_LEVEL_MAX=3
# Bluetooth-LE transport (XIAOMI_TRANSPORT=ble) for BLE-only gear like the
# camping lamp (hoto.light.lamp) that's never on Wi-Fi. Needs `pip install bleak`
# and a Terminal granted Bluetooth permission. Populate MAC + TOKEN in one step:
#   python -m actuators.xiaomi --ble-token   (QR login -> writes these keys)
# TOKEN is the device's 32-hex token (NOT the beaconkey). Find the MAC alone with
#   python -m actuators.xiaomi_ble --scan
XIAOMI_BLE_MAC=
XIAOMI_BLE_NAME=hoto.light.lamp
XIAOMI_BLE_TOKEN=
XIAOMI_BLE_SIID=2
XIAOMI_BLE_PIID_ON=1
XIAOMI_BLE_PIID_BRIGHT=2

# Scent diffuser (non-Xiaomi) — EITHER a webhook (Home Assistant / Shelly / IFTTT) ...
SCENT_WEBHOOK_URL=
# ... OR reuse the Broadlink IR blaster with learned diffuser codes (hex).
SCENT_IR_ON=
SCENT_IR_OFF=

# Telegram staff notifications.
#   @BotFather -> /newbot -> TELEGRAM_TOKEN
#   message the bot, then: python -m actuators.notify --chat-id  -> TELEGRAM_CHAT_ID
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Optional shared secret: if set, producers must send it as X-Token on /ingest + /frame
INGEST_TOKEN=

# LLM backup (Gemini AI Studio key, format AIza... ) — used when ANTHROPIC_API_KEY absent
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
