# ---------------------------------------------------------------------------
# Coffee Steve — web app environment
# Copy to `.env.local` and fill in real values: `cp .env.local.example .env.local`
# ---------------------------------------------------------------------------

# Clerk — auth, sessions, sign-up, organizations (multi-venue tenancy).
# Get keys from https://dashboard.clerk.com → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk redirect/route config.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# This app's own public URL (used for absolute links / metadata).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# The live product. The authed app links/embeds these.
NEXT_PUBLIC_DASHBOARD_URL=https://golden-coffee-production.up.railway.app
# Floorplan scanner PWA (defaults to DASHBOARD_URL + /scan/ if unset).
NEXT_PUBLIC_SCAN_URL=https://golden-coffee-production.up.railway.app/scan/
